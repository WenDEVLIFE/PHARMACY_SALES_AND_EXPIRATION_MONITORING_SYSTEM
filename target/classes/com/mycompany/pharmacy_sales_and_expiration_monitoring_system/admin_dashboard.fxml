<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" spacing="30.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharmacy_sales_and_expiration_monitoring_system.ui.AdminDashboardController" style="-fx-background-color: #f4f7f6;">
    <children>
        <Label text="Admin Dashboard">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#handleInventory" prefHeight="100.0" prefWidth="200.0" text="Inventory Management" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button mnemonicParsing="false" onAction="#handleSales" prefHeight="100.0" prefWidth="200.0" text="Sales POS" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold;"/>
                <Button mnemonicParsing="false" onAction="#handleReports" prefHeight="100.0" prefWidth="200.0" text="Sales Reports" style="-fx-background-color: #f1c40f; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </children>
        </HBox>

        <Button mnemonicParsing="false" onAction="#handleLogout" text="Logout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </children>
    <padding>
        <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
    </padding>
</VBox>
