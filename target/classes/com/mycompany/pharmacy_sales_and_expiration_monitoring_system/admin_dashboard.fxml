<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharmacy_sales_and_expiration_monitoring_system.ui.AdminDashboardController" styleClass="main-bg">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@assets/logo.jpg" />
            </image>
        </ImageView>
        <Label text="Admin Dashboard" styleClass="header-label">
            <font>
                <Font size="32.0" />
            </font>
        </Label>
        
        <HBox alignment="CENTER" spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <Button mnemonicParsing="false" onAction="#handleInventory" prefHeight="150.0" prefWidth="200.0" text="Inventory Management" styleClass="button-primary" style="-fx-font-size: 14;"/>
                <Button mnemonicParsing="false" onAction="#handleSales" prefHeight="150.0" prefWidth="200.0" text="Sales POS" styleClass="button-secondary" style="-fx-font-size: 14;"/>
                <Button mnemonicParsing="false" onAction="#handleReports" prefHeight="150.0" prefWidth="200.0" text="Sales Reports" styleClass="button-accent" style="-fx-font-size: 14;"/>
            </children>
        </HBox>

        <Button mnemonicParsing="false" onAction="#handleLogout" text="Logout" styleClass="button-danger" prefWidth="100.0"/>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>
</VBox>
