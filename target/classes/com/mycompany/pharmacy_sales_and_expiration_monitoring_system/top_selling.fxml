<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<VBox alignment="TOP_CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharmacy_sales_and_expiration_monitoring_system.ui.TopSellingController" styleClass="main-bg">
    <stylesheets>
        <URL value="@style.css" />
    </stylesheets>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0" prefWidth="Infinity">
            <children>
                <Label text="Top 5 Selling Products" styleClass="header-label">
                    <font>
                        <Font size="32.0" />
                    </font>
                </Label>
                <HBox HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#handleBack" text="Back" styleClass="button-primary" prefWidth="100.0" />
            </children>
        </HBox>
        
        <HBox alignment="CENTER" spacing="10.0" styleClass="card">
            <children>
                <Label text="Month (YYYY-MM):" />
                <TextField fx:id="monthField" prefWidth="150.0" promptText="e.g. 2026-03" />
                <Button mnemonicParsing="false" onAction="#handleAnalyze" text="Analyze" styleClass="button-secondary" />
            </children>
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
        </HBox>

        <VBox fx:id="resultsBox" alignment="CENTER" spacing="15.0" VBox.vgrow="ALWAYS" visible="false">
            <children>
                <Label fx:id="titleLabel" text="MONTHLY TOP 5 SELLING PRODUCTS" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                
                <TableView fx:id="topSellingTable" maxWidth="600.0">
                    <columns>
                        <TableColumn fx:id="rankCol" text="Rank" prefWidth="60.0" />
                        <TableColumn fx:id="productNameCol" text="Product Name" prefWidth="350.0" />
                        <TableColumn fx:id="qtySoldCol" text="Qty Sold" prefWidth="150.0" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
</VBox>
