<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharmacy_sales_and_expiration_monitoring_system.ui.ReportsController" style="-fx-background-color: #f4f7f6;">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label text="Sales Reports">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Button text="Back" onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
            </children>
        </HBox>

        <VBox spacing="10.0" VBox.vgrow="ALWAYS">
            <children>
                <Label text="Today's Sales Summary">
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Label>
                <TableView fx:id="reportsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="saleIdCol" prefWidth="100.0" text="Sale ID" />
                        <TableColumn fx:id="cashierCol" prefWidth="150.0" text="Cashier ID" />
                        <TableColumn fx:id="dateCol" prefWidth="200.0" text="Date &amp; Time" />
                        <TableColumn fx:id="amountCol" prefWidth="150.0" text="Total Amount" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
