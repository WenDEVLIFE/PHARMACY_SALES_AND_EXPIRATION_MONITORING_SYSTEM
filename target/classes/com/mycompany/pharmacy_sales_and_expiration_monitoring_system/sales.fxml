<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.pharmacy_sales_and_expiration_monitoring_system.ui.SalesController" style="-fx-background-color: #f4f7f6;">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label text="Point of Sale (POS)">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Button text="Back" onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white;"/>
            </children>
        </HBox>

        <HBox spacing="20.0" VBox.vgrow="ALWAYS">
            <children>
                <!-- Available Products Search -->
                <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label text="Search Products" />
                        <TextField fx:id="searchField" promptText="Enter product name..." />
                        <TableView fx:id="productSearchTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="searchNameCol" prefWidth="180.0" text="Product Name" />
                                <TableColumn fx:id="searchPriceCol" prefWidth="80.0" text="Price" />
                                <TableColumn fx:id="searchStockCol" prefWidth="80.0" text="Stock" />
                                <TableColumn fx:id="searchActionCol" prefWidth="100.0" text="Action" />
                            </columns>
                        </TableView>
                    </children>
                </VBox>

                <!-- Shopping Cart -->
                <VBox spacing="10.0" minWidth="400.0" style="-fx-background-color: white; -fx-padding: 20; -fx-border-color: #ddd; -fx-border-radius: 5;">
                    <children>
                        <Label text="Current Cart">
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Label>
                        <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="cartNameCol" prefWidth="150.0" text="Product" />
                                <TableColumn fx:id="cartQtyCol" prefWidth="60.0" text="Qty" />
                                <TableColumn fx:id="cartPriceCol" prefWidth="80.0" text="Price" />
                                <TableColumn fx:id="cartSubtotalCol" prefWidth="90.0" text="Subtotal" />
                            </columns>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label text="TOTAL: ">
                                    <font>
                                        <Font name="System Bold" size="18.0" />
                                    </font>
                                </Label>
                                <Label fx:id="totalLabel" text="0.00" textFill="#2ecc71">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#handleCheckout" prefWidth="Infinity" text="COMPLETE TRANSACTION" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10;"/>
                        <Button mnemonicParsing="false" onAction="#handleClearCart" prefWidth="Infinity" text="Clear Cart" style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
